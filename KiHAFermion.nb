Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ansatz1test", "=", 
    RowBox[{
     RowBox[{"dot", "[", 
      RowBox[{
       RowBox[{"p", "[", "i", "]"}], ",", 
       RowBox[{"F", "[", "j", "]"}], ",", 
       RowBox[{"F", "[", "j", "]"}], ",", 
       RowBox[{"F", "[", "j", "]"}], ",", 
       RowBox[{"lI", "[", "1", "]"}]}], "]"}], " ", 
     RowBox[{"spp", "[", 
      RowBox[{
       RowBox[{"spA", "[", 
        RowBox[{"p", "[", "5", "]"}], "]"}], ",", 
       RowBox[{"lI", "[", "1", "]"}], ",", 
       RowBox[{"spB", "[", 
        RowBox[{"p", "[", "4", "]"}], "]"}]}], "]"}]}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sum1", "=", "0"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"i", "=", "1"}], ",", 
    RowBox[{"i", "\[LessEqual]", "4"}], ",", 
    RowBox[{"i", "++"}], ",", 
    RowBox[{
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"j", "=", "1"}], ",", 
       RowBox[{"j", "\[LessEqual]", "3"}], ",", 
       RowBox[{"j", "++"}], ",", 
       RowBox[{
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"j2", "=", "1"}], ",", 
          RowBox[{"j2", "\[LessEqual]", "3"}], ",", 
          RowBox[{"j2", "++"}], ",", 
          RowBox[{
           RowBox[{"For", "[", 
            RowBox[{
             RowBox[{"j3", "=", "1"}], ",", 
             RowBox[{"j3", "\[LessEqual]", "3"}], ",", 
             RowBox[{"j3", "++"}], ",", 
             RowBox[{
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"j", "\[NotEqual]", "j2"}], "&&", 
                 RowBox[{"j", "\[NotEqual]", "j3"}], "&&", 
                 RowBox[{"j2", "\[NotEqual]", "j3"}]}], ",", 
                RowBox[{
                 RowBox[{"sum1", "+=", 
                  RowBox[{
                   RowBox[{"dot", "[", 
                    RowBox[{
                    RowBox[{"p", "[", "i", "]"}], ",", 
                    RowBox[{"F", "[", "j", "]"}], ",", 
                    RowBox[{"F", "[", "j2", "]"}], ",", 
                    RowBox[{"F", "[", "j3", "]"}], ",", 
                    RowBox[{"lI", "[", "1", "]"}]}], "]"}], " ", 
                   RowBox[{"spp", "[", 
                    RowBox[{
                    RowBox[{"spA", "[", 
                    RowBox[{"p", "[", "5", "]"}], "]"}], ",", 
                    RowBox[{"lI", "[", "1", "]"}], ",", 
                    RowBox[{"spB", "[", 
                    RowBox[{"p", "[", "4", "]"}], "]"}]}], "]"}]}]}], ";"}]}],
                "]"}], ";"}]}], "]"}], ";"}]}], "]"}], ";"}]}], "]"}], 
     ";"}]}], "]"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ansatz1test", "=", "sum1"}], 
  "\[IndentingNewLine]"}], "\n"}], "Input",
